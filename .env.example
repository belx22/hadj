# Copié vers .env avant de lancer `docker compose up --build`.

# Port exposé sur l'hôte (le conteneur Nginx écoute sur le port 80 en interne).
# Serveur de démo : http://62.169.26.178:4456
FRONTEND_PORT=4456

# --- Frontend (variables figées au build par Vite) ---
# Le frontend n'a pas d'autre source de données que le backend : sans backend
# joignable, l'interface reste vide (aucun repli en mémoire).
VITE_API_BASE_URL=/api/v1
VITE_DEFAULT_LOCALE=fr

# --- Base de données PostgreSQL ---
POSTGRES_DB=copilote_hadj
POSTGRES_USER=copilote
POSTGRES_PASSWORD=copilote

# --- Backend Spring Boot ---
# Port publié sur la boucle locale (127.0.0.1) uniquement : sert au proxy du
# serveur de dev Vite. Le trafic de production passe par Nginx (FRONTEND_PORT).
BACKEND_PORT=8081
# Clé HMAC du JWT — À CHANGER EN PRODUCTION (≥ 32 caractères).
COPILOTE_JWT_SECRET=copilote-hadj-secret-key-change-me-in-production-please-1234567890
# Origines autorisées par le CORS (CSV). En prod, mettre l'URL publique du front.
COPILOTE_CORS_ORIGINS=http://localhost:4456,http://62.169.26.178:4456
# Injecte le jeu de démonstration au premier démarrage si la base est vide.
COPILOTE_SEED_ENABLED=true

# --- Paiement en ligne (Payment Hub — pay.bbcomplex.com) ---
# Le bouton « Payer en ligne » (espace pèlerin) n'apparaît que si activé ET
# configuré. La clé d'API et le secret restent côté serveur (jamais dans le
# navigateur) : ils servent aux appels serveur→serveur et à vérifier le webhook.
PAYMENT_HUB_ENABLED=false
PAYMENT_HUB_BASE_URL=https://pay.bbcomplex.com
PAYMENT_HUB_API_KEY=
PAYMENT_HUB_SECRET=
PAYMENT_HUB_CURRENCY=XAF
# Adresse de notification à déclarer côté Hub (console) pour cette application :
#   https://hadj.afb-firstagent.com/api/v1/versements/paiement-en-ligne/webhook

# Copié vers .env avant de lancer `docker compose up --build`.

# Port exposé sur l'hôte (le conteneur Nginx écoute sur le port 80 en interne).
# Serveur de démo : http://62.169.26.178:4456
FRONTEND_PORT=4456

# Variables injectées au moment du build de l'image (Vite les fige dans le bundle
# final — voir frontend/.env.example pour le détail de chaque variable).
VITE_API_BASE_URL=/api/v1
VITE_USE_MOCK=true
VITE_DEFAULT_LOCALE=fr

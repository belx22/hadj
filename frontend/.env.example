# URL de base de l'API backend (Spring Boot).
# Non utilisée tant que VITE_USE_MOCK=true (le backend n'est pas encore livré).
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Mode mock : l'application fonctionne entièrement en mémoire (données de démo,
# pas d'appel réseau réel) tant que le backend Spring Boot n'est pas branché.
# Passer à "false" une fois le backend disponible pour utiliser VITE_API_BASE_URL.
VITE_USE_MOCK=true

# Langue par défaut de l'interface (fr | ar)
VITE_DEFAULT_LOCALE=fr

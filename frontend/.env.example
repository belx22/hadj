# Copier vers .env pour le développement local (`npm run dev`).

# URL de base de l'API. On garde un chemin relatif : en dev, le serveur Vite
# proxifie /api vers VITE_PROXY_TARGET (voir vite.config.js) ; en production,
# Nginx proxifie /api vers le conteneur backend.
VITE_API_BASE_URL=/api/v1

# Cible du proxy de développement (backend Spring Boot).
# `docker compose up` publie le backend sur 127.0.0.1:8081 (BACKEND_PORT).
VITE_PROXY_TARGET=http://localhost:8081

# Mode mock : démo autonome en mémoire, SANS backend ni base de données.
# false (défaut) = l'application consomme le backend réel.
# true = données simulées + bandeau "Mode démonstration" dans l'interface.
VITE_USE_MOCK=false

# Langue par défaut de l'interface (fr | ar | en)
VITE_DEFAULT_LOCALE=fr
